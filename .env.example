# URL the extension fetches the bucket schedule + kill switch + banner from.
# Defaults to the public raw-GitHub URL — edit bucket-schedule.json in the
# kev1n/better-caesar-schedule repo and push to update all clients (with
# 30 min client cache).
BC_BUCKET_SCHEDULE_URL=https://raw.githubusercontent.com/kev1n/better-caesar-schedule/main/bucket-schedule.json
